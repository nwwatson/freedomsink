<% content_for(:title, t('unsubscribes.create.title')) %>

<div class="unsubscribe-page">
  <h1 class="unsubscribe-page__heading"><%= t('unsubscribes.create.title') %></h1>
  <p class="unsubscribe-page__message">
    <%= t('unsubscribes.create.removed_html', email: @subscriber.email) %>
  </p>
  <p class="unsubscribe-page__sub-message"><%= t('unsubscribes.create.no_more_newsletters') %></p>

  <div class="unsubscribe-page__action">
    <%= link_to t('unsubscribes.create.return_to_site'), root_path,
          class: "btn btn--primary" %>
  </div>
</div>
