<% content_for(:title, "Categories — #{site_name}") %>

<div class="space-y-6">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <h1 class="text-2xl font-bold text-gray-900"><%= t('admin.categories.index.title') %></h1>
    <%= link_to t('admin.categories.index.new_category'), new_admin_category_path, class: "self-start rounded-md bg-gray-900 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-gray-700" %>
  </div>

  <% if @categories.any? %>
    <%# Mobile card layout %>
    <div class="space-y-3 lg:hidden">
      <% @categories.each do |category| %>
        <%= link_to edit_admin_category_path(category), class: "block rounded-lg bg-white p-4 shadow ring-1 ring-gray-200" do %>
          <div class="flex items-center justify-between">
            <p class="text-sm font-medium text-gray-900"><%= category.name %></p>
            <p class="text-sm text-gray-500"><%= category.posts.count %> posts</p>
          </div>
          <p class="mt-1 text-xs text-gray-500 font-mono"><%= category.slug %></p>
        <% end %>
      <% end %>
    </div>

    <%# Desktop table layout %>
    <div class="hidden overflow-hidden bg-white shadow ring-1 ring-gray-200 sm:rounded-lg lg:block">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500"><%= t('admin.categories.index.name') %></th>
            <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500"><%= t('admin.categories.index.slug') %></th>
            <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500"><%= t('admin.categories.index.posts') %></th>
            <th class="relative px-6 py-3"><span class="sr-only">Actions</span></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 bg-white">
          <% @categories.each do |category| %>
            <tr>
              <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= category.name %></td>
              <td class="px-6 py-4 text-sm text-gray-500"><%= category.slug %></td>
              <td class="px-6 py-4 text-sm text-gray-500"><%= category.posts.count %></td>
              <td class="whitespace-nowrap px-6 py-4 text-right text-sm font-medium">
                <%= link_to t('shared.edit'), edit_admin_category_path(category), class: "text-gray-600 hover:text-gray-900" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="rounded-lg border-2 border-dashed border-gray-300 p-12 text-center">
      <h3 class="text-sm font-semibold text-gray-900"><%= t('admin.categories.index.no_categories') %></h3>
      <p class="mt-1 text-sm text-gray-500"><%= t('admin.categories.index.get_started') %></p>
      <div class="mt-6">
        <%= link_to t('admin.categories.index.new_category'), new_admin_category_path, class: "rounded-md bg-gray-900 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-gray-700" %>
      </div>
    </div>
  <% end %>
</div>
